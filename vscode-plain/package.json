{
    "name": "plain-language",
    "displayName": "Plain Language",
    "description": "Syntax highlighting for the Plain programming language",
    "version": "0.1.0",
    "publisher": "tylerjforstrom",
    "engines": {
        "vscode": "^1.50.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "plain-lang",
                "aliases": [
                    "Plain",
                    "plain"
                ],
                "extensions": [
                    ".plain"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "plain-lang",
                "scopeName": "source.plain",
                "path": "./syntaxes/plain.tmLanguage.json"
            }
        ]
    }
}
