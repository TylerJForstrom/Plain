# Plain language test suite
# Run:  python plain.py tests.plain
# Every line should print OK. Any FAIL means something is broken.

# --- Arithmetic ---
expect 2 plus 3 to equal 5
expect 10 minus 4 to equal 6
expect 3 multiplied by 4 to equal 12
expect 10 divided by 4 to equal 2.5
expect remainder of 10 divided by 3 to equal 1
expect remainder of 9 divided by 3 to equal 0
expect floor of 3.9 to equal 3
expect middle of 1 and 10 to equal 5
expect middle of 1 and 6 to equal 3
expect square root of 81 to equal 9
expect round 4.6 to equal 5
expect 2 plus 3 multiplied by 4 to equal 14

set debt to negative 7
expect absolute value of debt to equal 7

# --- Lists ---
set nums to list of 3 and 1 and 2
expect count of nums to equal 3
expect sum of nums to equal 6
expect biggest in nums to equal 3
expect smallest in nums to equal 1
expect average of nums to equal 2
expect first of nums to equal 3
expect last of nums to equal 2

# indexing (positions start at 1)
expect item 2 of nums to equal 1
expect nums at 2 to equal 1
set item 2 of nums to 9
expect nums to equal list of 3 and 9 and 2
expect position of 9 in nums to equal 2
expect position of 100 in nums to equal 0

# sorting
sort nums
expect nums to equal list of 2 and 3 and 9
sort nums backwards
expect nums to equal list of 9 and 3 and 2

# add / remove
add 5 to nums
expect count of nums to equal 4
remove 5 from nums
expect count of nums to equal 3

# slicing
expect the first 2 of nums to equal list of 9 and 3
expect the last 1 of nums to equal list of 2

# map and filter
set squares to each n in list of 1 and 2 and 3 as n multiplied by n
expect squares to equal list of 1 and 4 and 9
set big to only the ones in list of 1 and 5 and 10 where it is greater than 4
expect big to equal list of 5 and 10

# --- Text ---
set word to "Hello"
expect uppercase of word to equal "HELLO"
expect lowercase of word to equal "hello"
expect count of word to equal 5
expect letters of "abc" to equal list of "a" and "b" and "c"
expect word at 1 to equal "H"
expect item 5 of word to equal "o"
expect the first 3 of word to equal "Hel"
expect the last 2 of word to equal "lo"
expect split "a,b,c" by "," to equal list of "a" and "b" and "c"
expect join list of "a" and "b" with "-" to equal "a-b"
expect value of "42" to equal 42

set chars to letters of "plain"
reverse chars
expect join chars with "" to equal "nialp"

# --- Lookups (key -> value tables) ---
set ages to empty lookup
set ages at "amy" to 30
set ages at "bob" to 25
expect ages at "amy" to equal 30
expect count of ages to equal 2
expect keys of ages to equal list of "amy" and "bob"
expect values of ages to equal list of 30 and 25

set table to lookup of "x" being 1 and "y" being 2
expect table at "y" to equal 2
remove "x" from table
expect count of table to equal 1

set flag to 0
if ages has "amy" then
    set flag to 1
end
expect flag to equal 1

set flag to 0
if "carl" is in ages then
    set flag to 1
end
expect flag to equal 0

# --- Conditions ---
set flag to 0
if 5 is at least 5 then
    add 1 to flag
end
if 5 is at most 5 then
    add 1 to flag
end
if 4 is at least 5 then
    add 100 to flag
end
expect flag to equal 2

set flag to 0
if "hello" contains "ell" then
    add 1 to flag
end
if "hello" starts with "he" then
    add 1 to flag
end
if "hello" ends with "lo" then
    add 1 to flag
end
expect flag to equal 3

set flag to 0
if list of 1 and 2 and 3 contains 2 then
    set flag to 1
end
expect flag to equal 1

set flag to 0
if 7 is not equal to 8 then
    set flag to 1
end
expect flag to equal 1

set flag to 0
if 7 is between 1 and 10 then
    set flag to 1
end
expect flag to equal 1

set flag to 0
if 9 is divisible by 3 then
    set flag to 1
end
expect flag to equal 1

# --- otherwise if chains ---
set grade to 85
set letter to ""
if grade is at least 90 then
    set letter to "A"
otherwise if grade is at least 80 then
    set letter to "B"
otherwise if grade is at least 70 then
    set letter to "C"
otherwise
    set letter to "F"
end
expect letter to equal "B"

# --- Loops ---
set total to 0
for each n from 1 to 100
    add n to total
end
expect total to equal 5050

set total to 0
set i to 0
while i is less than 5
    add 1 to i
    if i is equal to 3 then
        skip
    end
    if i is equal to 5 then
        stop
    end
    add i to total
end
expect total to equal 7

# --- Functions and recursion ---
to double with n
    give back n multiplied by 2
end
expect call double with 21 to equal 42

to fact with n
    if n is at most 1 then
        give back 1
    end
    set m to n minus 1
    give back n multiplied by call fact with m
end
expect call fact with 5 to equal 120

# --- Operator style (symbols work everywhere words do) ---
set x to (2 + 3) * 4
expect x to equal 20
x = 100
expect x to equal 100
x += 5
expect x to equal 105
x -= 5
x *= 2
x /= 4
expect x to equal 50
expect 7 % 3 to equal 1
expect 7 // 2 to equal 3
expect 2 ^ 10 to equal 1024
expect 3 squared to equal 9
expect -4 + 10 to equal 6
expect 10 - (2 + 3) to equal 5
expect "ab" + "cd" to equal "abcd"
expect round of (9 / 2) to equal 5

set flag to 0
if 3 < 5 then
    flag = 1
end
expect flag == 1

set flag to 0
if 5 >= 5 and 4 != 3 then
    flag = 1
end
expect flag == 1

set flag to 0
if (1 > 2) or (2 > 1) then
    flag = 1
end
expect flag == 1

# truthy conditions: a true/false value works by itself
set done to false
set flag to 0
if not done then
    flag = 1
end
expect flag == 1
set done to true
if done then
    flag = 2
end
expect flag == 2

# --- Bracket lists and brace lookups ---
set nums to [3, 1, 2]
expect nums to equal list of 3 and 1 and 2
expect nums[2] to equal 1
nums[2] = 9
expect nums[2] to equal 9
expect count of [] to equal 0

set ages to {"amy": 30, "bob": 25}
expect ages["amy"] to equal 30
ages["carl"] = 41
expect count of ages to equal 3
expect count of {} to equal 0

# --- Python-style function calls ---
to triple with n
    give back n * 3
end
expect triple(7) to equal 21
expect call triple with 7 to equal 21
expect triple(2 + 5) to equal 21

to shout
    give back "HEY"
end
expect shout() to equal "HEY"

# call ... with now takes whole expressions as arguments
to add_pair with a and b
    give back a + b
end
expect call add_pair with 2 + 3 and 10 to equal 15

# --- Nested lists and grids ---
set board to [[1, 2], [3, 4]]
expect board[2][1] to equal 3
board[1][2] = 99
expect board[1][2] to equal 99
set item 1 of item 2 of board to 7
expect board[2][1] to equal 7
set board at 2 at 2 to 8
expect board[2][2] to equal 8

set blank to grid of 2 by 3 filled with 0
expect count of blank to equal 2
expect count of blank[1] to equal 3
expect blank[2][3] to equal 0
expect blank to equal [[0, 0, 0], [0, 0, 0]]

# 'grid' still works as an ordinary variable name
set grid to [1, 2]
expect grid[2] to equal 2

# --- Nested loops in one line ---
set pairs to []
for each a from 1 to 3 and b from 1 to 2
    add "[a]-[b]" to pairs
end
expect count of pairs to equal 6
expect pairs[1] to equal "1-1"
expect pairs[6] to equal "3-2"

set total to 0
set rows to [[1, 2, 3], [4, 5]]
for each row in rows and cell in row
    total += cell
end
expect total to equal 15

# stop leaves the whole combined loop, skip moves to the next pair
set found to ""
for each a from 1 to 5 and b from 1 to 5
    if a * b == 12 and a < b then
        found = "[a]x[b]"
        stop
    end
end
expect found to equal "3x4"

set kept to []
for each a from 1 to 2 and b from 1 to 2
    if a == b then
        skip
    end
    add "[a]-[b]" to kept
end
expect kept to equal ["1-2", "2-1"]

# --- does not contain / have / start with / end with ---
set flag to 0
if "hello" does not contain "z" then
    flag += 1
end
if [1, 2] does not have 3 then
    flag += 1
end
if "hello" does not start with "z" then
    flag += 1
end
if "hello" does not end with "z" then
    flag += 1
end
if "hello" does not contain "ell" then
    flag += 100
end
expect flag to equal 4

# --- Stack and queue moves ---
set stack to []
add "x" to stack
add "y" to stack
add "z" to stack
remove the last from stack into top
expect top to equal "z"
expect count of stack to equal 2
remove the first from stack into front
expect front to equal "x"
expect stack to equal ["y"]

set q to [1, 2, 3, 4]
remove item 2 from q
expect q to equal [1, 3, 4]
remove item 1 from q into head
expect head to equal 1
insert 9 into q at 1
expect q to equal [9, 3, 4]
insert 5 into q at 4
expect q to equal [9, 3, 4, 5]

# --- swap ---
set a to 1
set b to 2
swap a and b
expect a to equal 2
expect b to equal 1
set nums to [10, 20, 30]
swap nums[1] and nums[3]
expect nums to equal [30, 20, 10]
swap a and nums[2]
expect a to equal 20
expect nums to equal [30, 2, 10]

# --- odd / even ---
set flag to 0
if 7 is odd then
    flag += 1
end
if 8 is even then
    flag += 1
end
if 7 is not even then
    flag += 1
end
if -3 is odd then
    flag += 1
end
expect flag to equal 4

# --- bigger of / smaller of ---
expect bigger of 3 and 7 to equal 7
expect smaller of 3 and 7 to equal 3
expect bigger of -2 and -5 to equal -2
set bigger to 99
expect bigger to equal 99

# --- Loops with positions ---
set seen_pairs to []
for each ch at position i in ["a", "b", "c"]
    add "[i]:[ch]" to seen_pairs
end
expect seen_pairs to equal ["1:a", "2:b", "3:c"]

set rev_pairs to []
for each ch at position i in ["a", "b"] going backwards
    add "[i]:[ch]" to rev_pairs
end
expect rev_pairs to equal ["2:b", "1:a"]

# --- sort by ---
set pairs to [[3, "c"], [1, "a"], [2, "b"]]
sort pairs by it[1]
expect pairs to equal [[1, "a"], [2, "b"], [3, "c"]]
sort pairs by it[1] backwards
expect pairs to equal [[3, "c"], [2, "b"], [1, "a"]]

set words to ["bee", "a", "spider"]
sort words by count of it
expect words to equal ["a", "bee", "spider"]

set scores to {"amy": 3, "bob": 9, "carl": 5}
set names to keys of scores
sort names by scores at it backwards
expect names to equal ["bob", "carl", "amy"]

print ""
print "Tests finished. Every line above should say OK."
